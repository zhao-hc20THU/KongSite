server {
    listen 80;
    listen [::]:80;
    server_name cemchem.cn www.cemchem.cn;

    root /var/www/cemchem.cn;
    index index.html;

    access_log /var/log/nginx/cemchem.cn.access.log;
    error_log /var/log/nginx/cemchem.cn.error.log;

    location / {
        try_files $uri $uri/ $uri.html =404;
    }

    location ~* \.(?:css|js|jpg|jpeg|gif|png|svg|ico|webp|woff2?)$ {
        expires 30d;
        add_header Cache-Control "public, max-age=2592000, immutable";
        try_files $uri =404;
    }
}

